config LORA_LR20XX
	bool "Semtech LR20xx LoRa transceiver driver"
	default y
	depends on DT_HAS_SEMTECH_LR2021_ENABLED
	select SPI
	select GPIO
	help
	  Enable driver for Semtech LR2021 (LoRa Plus, 4th-gen) transceivers.
	  Uses native Semtech lr20xx_driver SDK with Zephyr LoRa driver API.
	  Supports sub-GHz + 2.4 GHz ISM + NTN/SATCOM.
