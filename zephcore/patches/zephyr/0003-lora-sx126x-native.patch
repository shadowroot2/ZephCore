+			{ 2, 2, -5 }, { 2, 1,  0 }, { 1, 1,  3 }, { 1, 2,  0 },
+			{ 1, 1,  6 }, { 1, 2,  3 }, { 2, 2,  2 }, { 4, 1,  6 },
+			{ 1, 1, 11 }, { 2, 1, 11 }, { 1, 1, 14 }, { 2, 1, 14 },
+			{ 1, 1, 20 }, { 1, 1, 22 }, { 2, 2, 11 }, { 3, 1, 21 },
